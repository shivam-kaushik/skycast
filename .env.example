# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored — never commit real keys.

# ── Supabase (required for login / cross-device premium sync) ─────────────────
# Get from: https://app.supabase.com → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ── OpenAI (required for AI chat, wardrobe advisor, trip briefing) ────────────
# Get from: https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=sk-...

# ── RevenueCat (required for premium subscriptions) ───────────────────────────
# Get from: https://app.revenuecat.com → Project → API Keys
#
# Option A — single key (works for sandbox / both platforms):
EXPO_PUBLIC_RC_API_KEY=your_teststore_key_here
#
# Option B — separate keys per platform (use in production):
# EXPO_PUBLIC_RC_API_KEY_IOS=appl_...
# EXPO_PUBLIC_RC_API_KEY_ANDROID=goog_...
#
# NOTE: If both options are set, Option B takes precedence per platform.
